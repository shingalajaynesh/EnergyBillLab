{
  "name": "energy-bill-lab",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@energy-bill-lab/api",
    "build:web": "turbo run build --filter=@energy-bill-lab/web",
    "data:eia:backfill": "pnpm --filter=@energy-bill-lab/api exec tsx src/modules/electricity-rate-import/electricity-rate-import.cli.ts backfill",
    "data:eia:metadata": "pnpm --filter=@energy-bill-lab/api exec tsx src/modules/electricity-rate-import/electricity-rate-import.cli.ts metadata",
    "data:eia:sync": "pnpm --filter=@energy-bill-lab/api exec tsx src/modules/electricity-rate-import/electricity-rate-import.cli.ts sync",
    "data:eia:verify": "pnpm --filter=@energy-bill-lab/api exec tsx src/modules/electricity-rate-import/electricity-rate-import.cli.ts verify",
    "db:check": "pnpm --filter=@energy-bill-lab/database db:check",
    "db:generate": "pnpm --filter=@energy-bill-lab/database db:generate",
    "db:migrate": "pnpm --filter=@energy-bill-lab/database db:migrate",
    "db:seed:geographies": "pnpm --filter=@energy-bill-lab/database db:seed:geographies",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@energy-bill-lab/eslint-config": "workspace:*",
    "eslint": "^9.30.0",
    "prettier": "^3.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
