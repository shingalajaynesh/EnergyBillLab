{
  "name": "@energy-bill-lab/database",
  "private": true,
  "version": "0.0.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:check": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs check",
    "db:generate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed:geographies": "node --env-file=../../.env ../../node_modules/.bin/tsx src/seed/seed-geographies.ts",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "drizzle-orm": "^0.44.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@energy-bill-lab/eslint-config": "workspace:*",
    "@energy-bill-lab/typescript-config": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "vitest": "^3.2.0"
  }
}
